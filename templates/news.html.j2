<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>今日のニュース — {{ date }}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Hiragino Sans", sans-serif;
      background: #f0ede8;
      color: #2d2a26;
      line-height: 1.7;
    }

    /* ── ヘッダー ── */
    header {
      background: linear-gradient(135deg, #4a3f35, #6b5344);
      color: #fff;
      padding: 2.2rem 1.5rem 1.8rem;
      text-align: center;
    }
    header h1 {
      font-size: 1.7rem;
      font-weight: 700;
      letter-spacing: 0.03em;
    }
    header p {
      font-size: 0.85rem;
      color: #d4c4b5;
      margin-top: 0.4rem;
    }

    /* ── ナビ ── */
    nav {
      display: flex;
      gap: 0.5rem;
      justify-content: center;
      flex-wrap: wrap;
      padding: 0.9rem 1rem;
      background: #e8e2da;
      border-bottom: 1px solid #d0c8be;
      position: sticky;
      top: 0;
      z-index: 10;
    }
    nav a {
      text-decoration: none;
      font-size: 0.8rem;
      padding: 0.3rem 1rem;
      border-radius: 999px;
      background: #fff;
      border: 1px solid #c8bfb5;
      color: #5a4f45;
      transition: background 0.15s, color 0.15s;
    }
    nav a:hover {
      background: #6b5344;
      color: #fff;
      border-color: #6b5344;
    }

    /* ── メインコンテンツ ── */
    main {
      max-width: 820px;
      margin: 2rem auto;
      padding: 0 1rem;
      display: flex;
      flex-direction: column;
      gap: 2.5rem;
    }

    /* ── カテゴリ見出し ── */
    .category-header {
      display: flex;
      align-items: center;
      gap: 0.7rem;
      margin-bottom: 1rem;
    }
    .category-header h2 {
      font-size: 1.05rem;
      font-weight: 700;
      color: #4a3f35;
    }
    .category-line {
      flex: 1;
      height: 2px;
      background: linear-gradient(to right, #c8a882, transparent);
      border-radius: 1px;
    }
    .category-count {
      font-size: 0.75rem;
      color: #9a8878;
      background: #e8e2da;
      padding: 0.15rem 0.6rem;
      border-radius: 999px;
    }

    /* ── カード ── */
    .card {
      background: #faf7f4;
      border-radius: 12px;
      border: 1px solid #e0d8d0;
      border-left: 4px solid #c8a882;
      padding: 1.2rem 1.4rem;
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      margin-bottom: 0.8rem;
      transition: box-shadow 0.15s, transform 0.15s;
    }
    .card:hover {
      box-shadow: 0 4px 16px rgba(74, 63, 53, 0.12);
      transform: translateY(-1px);
    }

    .card-meta {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.75rem;
      color: #9a8878;
    }
    .badge {
      display: inline-block;
      padding: 0.15rem 0.6rem;
      border-radius: 999px;
      font-size: 0.7rem;
      font-weight: 600;
      background: #ede5db;
      color: #6b5344;
    }

    .card h3 {
      font-size: 0.98rem;
      font-weight: 700;
      line-height: 1.5;
      color: #2d2a26;
    }
    .card h3 a {
      color: inherit;
      text-decoration: none;
    }
    .card h3 a:hover {
      color: #6b5344;
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .card p {
      font-size: 0.875rem;
      color: #5a524a;
      line-height: 1.7;
      border-top: 1px solid #e8e2da;
      padding-top: 0.5rem;
    }

    .read-more {
      font-size: 0.78rem;
      color: #6b5344;
      text-decoration: none;
      font-weight: 600;
      align-self: flex-end;
    }
    .read-more:hover { text-decoration: underline; }

    /* ── フッター ── */
    footer {
      text-align: center;
      font-size: 0.75rem;
      color: #9a8878;
      padding: 2.5rem 1rem;
      border-top: 1px solid #d0c8be;
      margin-top: 1rem;
    }
  </style>
</head>
<body>

<header>
  <h1>📰 今日のニュース</h1>
  <p>{{ date }} ・ {{ articles | length }} 本</p>
</header>

<nav>
  <a href="#top">すべて</a>
  {% for cat in categories %}
  <a href="#{{ cat | replace('・', '-') | replace('　', '-') }}">{{ cat }}</a>
  {% endfor %}
</nav>

<main id="top">
  {% for cat in categories %}
  {% set cat_articles = articles | selectattr("category", "equalto", cat) | list %}
  {% if cat_articles %}
  <section id="{{ cat | replace('・', '-') | replace('　', '-') }}">
    <div class="category-header">
      <h2>{{ cat }}</h2>
      <div class="category-line"></div>
      <span class="category-count">{{ cat_articles | length }}本</span>
    </div>

    {% for article in cat_articles %}
    <div class="card">
      <div class="card-meta">
        <span class="badge">{{ article.source }}</span>
        <span>{{ article.published }}</span>
      </div>
      <h3><a href="{{ article.url }}" target="_blank" rel="noopener">{{ article.title }}</a></h3>
      {% if article.summary %}
      <p>{{ article.summary }}</p>
      {% endif %}
      <a class="read-more" href="{{ article.url }}" target="_blank" rel="noopener">続きを読む →</a>
    </div>
    {% endfor %}
  </section>
  {% endif %}
  {% endfor %}
</main>

<footer>
  生成日時: {{ generated_at }} ・ Powered by Gemini &amp; GitHub Actions
</footer>

</body>
</html>
