<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>今日のニュース — {{ date }}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #f5f5f5;
      color: #1a1a1a;
      line-height: 1.6;
    }

    header {
      background: #1a1a2e;
      color: #fff;
      padding: 2rem 1.5rem 1.5rem;
      text-align: center;
    }
    header h1 { font-size: 1.6rem; font-weight: 700; }
    header p  { font-size: 0.85rem; color: #aaa; margin-top: 0.3rem; }

    nav {
      display: flex;
      gap: 0.5rem;
      justify-content: center;
      flex-wrap: wrap;
      padding: 1rem;
      background: #fff;
      border-bottom: 1px solid #e0e0e0;
      position: sticky;
      top: 0;
      z-index: 10;
    }
    nav a {
      text-decoration: none;
      font-size: 0.8rem;
      padding: 0.3rem 0.8rem;
      border-radius: 999px;
      border: 1px solid #ccc;
      color: #444;
      transition: background 0.15s;
    }
    nav a:hover { background: #1a1a2e; color: #fff; border-color: #1a1a2e; }

    main {
      max-width: 800px;
      margin: 2rem auto;
      padding: 0 1rem;
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    section h2 {
      font-size: 1rem;
      font-weight: 700;
      color: #555;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      border-left: 4px solid #1a1a2e;
      padding-left: 0.6rem;
      margin-bottom: 1rem;
    }

    .card {
      background: #fff;
      border-radius: 10px;
      padding: 1.2rem 1.4rem;
      box-shadow: 0 1px 4px rgba(0,0,0,0.08);
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      margin-bottom: 0.8rem;
    }
    .card-meta {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.75rem;
      color: #888;
    }
    .badge {
      display: inline-block;
      padding: 0.15rem 0.55rem;
      border-radius: 999px;
      font-size: 0.7rem;
      font-weight: 600;
      background: #e8eaf6;
      color: #3949ab;
    }
    .card h3 {
      font-size: 1rem;
      font-weight: 700;
      line-height: 1.4;
    }
    .card h3 a {
      color: inherit;
      text-decoration: none;
    }
    .card h3 a:hover { text-decoration: underline; color: #1a1a2e; }
    .card p {
      font-size: 0.88rem;
      color: #444;
      line-height: 1.65;
    }
    .tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
      margin-top: 0.2rem;
    }
    .tag {
      font-size: 0.7rem;
      background: #f0f0f0;
      color: #666;
      padding: 0.1rem 0.5rem;
      border-radius: 4px;
    }

    footer {
      text-align: center;
      font-size: 0.75rem;
      color: #aaa;
      padding: 2rem 1rem;
    }
  </style>
</head>
<body>

<header>
  <h1>📰 今日のニュース</h1>
  <p>{{ date }} ・ {{ articles | length }} 本</p>
</header>

<nav>
  <a href="#top">すべて</a>
  {% for cat in categories %}
  <a href="#{{ cat | replace('・', '-') | replace('　', '-') }}">{{ cat }}</a>
  {% endfor %}
</nav>

<main id="top">
  {% for cat in categories %}
  {% set cat_articles = articles | selectattr("category", "equalto", cat) | list %}
  {% if cat_articles %}
  <section id="{{ cat | replace('・', '-') | replace('　', '-') }}">
    <h2>{{ cat }}</h2>
    {% for article in cat_articles | sort(attribute='importance', reverse=True) %}
    <div class="card">
      <div class="card-meta">
        <span class="badge">{{ article.source }}</span>
        <span>{{ article.published }}</span>
      </div>
      <h3><a href="{{ article.url }}" target="_blank" rel="noopener">{{ article.title }}</a></h3>
      <p>{{ article.summary }}</p>
      {% if article.tags %}
      <div class="tags">
        {% for tag in article.tags %}
        <span class="tag"># {{ tag }}</span>
        {% endfor %}
      </div>
      {% endif %}
    </div>
    {% endfor %}
  </section>
  {% endif %}
  {% endfor %}
</main>

<footer>
  生成日時: {{ generated_at }} ・ Powered by Gemini &amp; GitHub Actions
</footer>

</body>
</html>
